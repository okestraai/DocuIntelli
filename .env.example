# ═══════════════════════════════════════════════════════════════
# DocuIntelli Environment Variables (Azure Architecture)
# ═══════════════════════════════════════════════════════════════
#
# BUILD-TIME vars (VITE_ prefix) are baked into the frontend JS
# bundle by Vite. Changing them requires a Docker image rebuild:
#   docker compose build web
#
# RUNTIME vars are read by the Express server at startup.
# Changing them only requires a container restart:
#   docker compose restart web
#
# ═══════════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────────
PORT=5000

# ─── Azure Database for PostgreSQL ───────────────────────────
DATABASE_URL=postgresql://user:password@yourserver.postgres.database.azure.com:5432/docuintelli?sslmode=verify-full

# ─── Azure Blob Storage ─────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=documents

# ─── Custom JWT Auth ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-char-hex-key
JWT_REFRESH_SECRET=your-64-char-hex-key

# ─── Google OAuth (optional — fill in to enable Google login) ─
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Stripe (BUILD-TIME — price IDs used in frontend) ───────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
VITE_STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxx
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
VITE_STRIPE_STARTER_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx
VITE_STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx

# ─── Stripe (RUNTIME — server-side) ─────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_STARTER_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STARTER_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx

# ─── vLLM API (RUNTIME) ─────────────────────────────────────
VLLM_EMBEDDER_URL=https://embedder.affinityecho.com
VLLM_CHAT_URL=https://chat.affinityecho.com
CF_ACCESS_CLIENT_ID=your-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=your-cloudflare-access-client-secret

# ─── Local Embedding Fallback (RUNTIME, optional) ───────────
EMBEDDING_API_URL=http://localhost:8001/v1/embeddings
EMBEDDING_MODEL=intfloat/e5-mistral-7b-instruct
EMBEDDING_DIMENSIONS=4096

# ─── Email / Mailjet SMTP (RUNTIME) ─────────────────────────
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=your-mailjet-api-key
SMTP_PASS=your-mailjet-secret-key
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=DocuIntelli AI
SUPPORT_EMAIL=support@yourdomain.com
APP_URL=https://app.yourdomain.com

# ─── CORS (RUNTIME) ─────────────────────────────────────────
ALLOWED_ORIGINS=https://app.yourdomain.com

# ─── Plaid Financial Insights (RUNTIME) ──────────────────────
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# ─── Redis (RUNTIME) ────────────────────────────────────────
# Self-hosted Docker Redis or Azure Cache for Redis
# For Docker Compose: redis://redis:6379
# For self-hosted: redis://localhost:6380
# For Azure Redis: rediss://:accesskey@hostname.redis.cache.windows.net:6380
# Leave unset to fall back to in-memory (no caching)
# REDIS_URL=redis://localhost:6380
